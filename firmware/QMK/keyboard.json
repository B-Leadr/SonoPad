{
    "manufacturer": "Benjamin Leader",
    "keyboard_name": "sonopad",
    "maintainer": "B-Leadr",
    "bootloader": "rp2040",
    "diode_direction": "COL2ROW",
    "features": {
        "bootmagic": true,
        "extrakey": true,
        "mousekey": true,
        "nkro": true,
        "encoder": true,
        "oled": true
    },
    "matrix_pins": {
        "cols": ["GP3", "GP4", "GP1", "GP18"],
        "rows": ["GP29", "GP0"]
    },
    "processor": "RP2040",
    "url": "https://github.com/B-Leadr/SonoPad",
    "usb": {
        "device_version": "1.0.0",
        "pid": "0x0008",
        "vid": "0xFEED"
    },
    "layouts": {
        "LAYOUT": {
            "layout": [
                {"matrix": [0, 0], "x": 0, "y": 0},
                {"matrix": [0, 1], "x": 1, "y": 0},
                {"matrix": [0, 2], "x": 2, "y": 0},
                {"matrix": [0, 3], "x": 3, "y": 0},
                {"matrix": [1, 0], "x": 0, "y": 1},
                {"matrix": [1, 1], "x": 1, "y": 1},
                {"matrix": [1, 2], "x": 2, "y": 1},
                {"matrix": [1, 3], "x": 3, "y": 1}
            ]
        }
    },
    "encoder": {
        "type": "rotary",
        "rotary": [
            { "pin_a": "GP27", "pin_b": "GP28", "resolution": 2}
        ],
        "functions": {
            "cw": "volume_up",
            "ccw": "volume_down"
        }
    },
    "oled": {
        "driver": "ssd1306",
        "transport": "i2c"
    }
}